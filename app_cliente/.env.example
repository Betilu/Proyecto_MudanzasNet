# Variables de entorno para la app cliente
# Copiar este archivo a .env y configurar los valores

# ============================================
# CONFIGURACIÓN DE BACKEND
# ============================================
# Esta es la ÚNICA variable que necesitas cambiar para conectar con tu backend

# Para desarrollo local:
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Para testing en dispositivo físico en misma red WiFi:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
# (Reemplaza 192.168.1.100 con la IP de tu computadora)

# Para servidor de staging:
# EXPO_PUBLIC_API_URL=https://staging.tudominio.com

# Para producción:
# EXPO_PUBLIC_API_URL=https://api.tudominio.com

# ============================================
# OTRAS CONFIGURACIONES
# ============================================

# Ambiente (development, staging, production)
EXPO_PUBLIC_ENV=development
